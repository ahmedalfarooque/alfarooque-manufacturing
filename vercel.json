{
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/images.js": { "includeFiles": "assets/images/{E-commerse Home Images,Steel Works,Aluminium Works}/**" }
  },
  "rewrites": [
    { "source": "/about",         "destination": "/pages/about" },
    { "source": "/services",      "destination": "/pages/services" },
    { "source": "/gallery",       "destination": "/pages/gallery" },
    { "source": "/contact",       "destination": "/pages/contact" },
    { "source": "/woodworks",     "destination": "/pages/woodworks" },
    { "source": "/steelworks",    "destination": "/pages/steelworks" },
    { "source": "/aluminium",     "destination": "/pages/aluminium" },
    { "source": "/about-ar",      "destination": "/pages/about-ar" },
    { "source": "/services-ar",   "destination": "/pages/services-ar" },
    { "source": "/gallery-ar",    "destination": "/pages/gallery-ar" },
    { "source": "/contact-ar",    "destination": "/pages/contact-ar" },
    { "source": "/woodworks-ar",  "destination": "/pages/woodworks-ar" },
    { "source": "/steelworks-ar", "destination": "/pages/steelworks-ar" },
    { "source": "/aluminium-ar",  "destination": "/pages/aluminium-ar" },
    { "source": "/admin",         "destination": "/pages/admin/login" }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/mohammed",
      "permanent": false,
      "has": [{ "type": "host", "value": "mohammed.alfarooque.com" }]
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(js|css)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
